{
  "name": "ai_game_workbench",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/server",
    "dev:workbench": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-workbench.ps1",
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w apps/server",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build:launcher": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-launcher.ps1",
    "test:launcher": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-launcher.ps1",
    "test:workbench-startup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-workbench-startup.ps1",
    "e2e:openrouter": "tsx scripts/run-openrouter-pipeline.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
